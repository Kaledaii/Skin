{
  "expo": {
    "name": "Prabha Skincare",
    "slug": "prabha-skincare",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "prabha",
    "icon": "./assets/brand/prabha-icon-1024.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/brand/prabha-logo-cream.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF8F5"
    },
    "ios": {
      "icon": "./assets/brand/prabha-icon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/prabha-adaptive-icon.png",
        "backgroundColor": "#F98B9E"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand/prabha-favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Skin Nepal uses your location to show local weather and air quality skincare guidance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
