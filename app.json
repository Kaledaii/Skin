{
  "expo": {
    "name": "Skin Nepal",
    "slug": "skin-nepal",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "skinnepal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Skin Nepal uses your location to show local weather and air quality skincare guidance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
