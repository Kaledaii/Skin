rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid))
      );
    }
    function isAuthenticated() {
      return request.auth != null;
    }

    // Payment requests: users may create their own request, read their own, admins may read/update
    match /paymentRequests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Only admins may modify admin fields (status, reviewedAt, reviewNote, assigneeAdminId)
      allow update: if isAdmin() || (
        isAuthenticated()
        && request.auth.uid == resource.data.userId
        // owners may update non-admin fields only (cannot set status/review fields)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          "status",
          "reviewedAt",
          "reviewNote",
          "assigneeAdminId"
        ])
      );
      allow delete: if isAdmin();
    }

    // Admin actions: only admins can write/read
    match /adminActions/{actionId} {
      allow read, write: if isAdmin();
    }

    // Admin allowlist: create the first document manually from Firebase Console.
    // Document id must be the admin Firebase Auth UID.
    match /adminUsers/{adminUid} {
      allow read: if isAuthenticated() && request.auth.uid == adminUid || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // Beta app reviews: signed-in/anonymous users can submit, admins can read/moderate
    match /appReviews/{reviewId} {
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.experience is string
        && request.resource.data.experience.size() >= 8
        && request.resource.data.experience.size() <= 1200;
      allow read, update, delete: if isAdmin();
    }

    // Users collection: users can read/write their own profile, admins can read/write all
    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAdmin() || (
        isAuthenticated() && request.auth.uid == userId
        // prevent users from escalating themselves: disallow changing subscription/payment fields
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          "subscription",
          "paymentState",
          "lastPaymentRequestId"
        ])
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // Other documents: default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
